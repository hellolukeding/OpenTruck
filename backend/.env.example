APP_ENV=development
APP_NAME=OpenTruck API
APP_HOST=0.0.0.0
APP_PORT=8000
GATEWAY_UPSTREAM_TIMEOUT_SECONDS=120
GATEWAY_UPSTREAM_FAILURE_THRESHOLD=3
GATEWAY_UPSTREAM_COOLDOWN_SECONDS=90
GATEWAY_UPSTREAM_DEFAULT_MAX_PARALLEL_REQUESTS=4
GATEWAY_QUOTA_COST_PER_1K_TOKENS=1
JWT_SECRET=opentruck-dev-secret-change-me-32chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_ISSUER=opentruck
JWT_AUDIENCE=opentruck-gateway

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=opentruck
POSTGRES_USER=opentruck
POSTGRES_PASSWORD=opentruck

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
